<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
    id="executionModeDialog"
    title="Modo de ejecución"
    type="Message"
    contentWidth="22rem">
    <content>
        <Text text="¿Cómo deseas ejecutar el proceso?" class="sapUiSmallMargin" />
    </content>
    <beginButton>
        <Button text="Ejecución en Diálogo" type="Emphasized" press=".onExecuteDialog" />
    </beginButton>
    <endButton>
        <Button text="Ejecución en Fondo" press=".onExecuteBackground" />
    </endButton>
</Dialog>
</core:FragmentDefinition>