<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
>
    <Dialog
        id="dialogEditarBusinessPartner"
        title="Editar Business Partner"
        contentWidth="800px"
        draggable="true"
        resizable="true"
    >
        <content>
            <form:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanL="4"
                labelSpanM="4"
                emptySpanL="0"
                emptySpanM="0"
                columnsL="2"
                columnsM="2"
            >
                <form:content>
                    <Label text="BusinessPartnerID" />
                    <Input
                        value="{businessPartner>BusinessPartnerID}"
                        maxLength="10"
                        liveChange=".onFieldChangeRoles"
                    />
                </form:content>
            </form:SimpleForm>
        </content>
        <buttons>
            <Button
                text="Guardar"
                type="Emphasized"
                press=".onGuardarRoles"
            />
            <Button
                text="Cancelar"
                press=".onCerrarDialogRoles"
            />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
